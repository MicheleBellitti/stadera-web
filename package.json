{
  "name": "stadera-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check --write ./src",
    "lint": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "api:openapi:fetch": "curl -fsS ${NEXT_PUBLIC_API_URL:-http://localhost:8080}/api-docs/openapi.json -o src/lib/api/openapi.json",
    "api:types": "openapi-typescript src/lib/api/openapi.json -o src/lib/api/types.ts",
    "api:codegen": "pnpm api:openapi:fetch && pnpm api:types",
    "verify": "biome check ./src && pnpm api:types && git diff --exit-code -- src/lib/api/types.ts && tsc --noEmit && next build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-devtools": "^5.100.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
